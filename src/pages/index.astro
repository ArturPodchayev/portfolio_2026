<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Artur Podchaev — Full-Stack Engineer, AI Systems, Product Builder from Tashkent.">
<title>Artur Podchaev // System Architect</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07050f;--surface:#0e0a1a;
  --border:rgba(103,232,194,0.07);--border2:rgba(103,232,194,0.16);
  --text:#f0eeff;--muted:rgba(240,238,255,0.38);
  --accent:#67e8c2;--purple:#4e16b3;--purpleL:#7b3fe4;
  --mono:'Space Mono',monospace;--sans:'Syne',sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);overflow-x:hidden;cursor:none}
#cur{position:fixed;width:8px;height:8px;background:var(--accent);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .18s,height .18s}
#cur-r{position:fixed;width:30px;height:30px;border:1px solid rgba(103,232,194,.32);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%)}
.grid-bg{position:fixed;inset:0;background-image:linear-gradient(rgba(103,232,194,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(103,232,194,.03) 1px,transparent 1px);background-size:64px 64px;pointer-events:none;z-index:0}
.blob{position:fixed;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0}
.blob-1{width:520px;height:520px;background:radial-gradient(circle,rgba(78,22,179,.22) 0%,transparent 70%);top:-120px;right:-100px}
.blob-2{width:380px;height:380px;background:radial-gradient(circle,rgba(103,232,194,.08) 0%,transparent 70%);bottom:25%;left:-80px}
.noise{position:fixed;inset:0;pointer-events:none;z-index:999;opacity:.028;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-size:120px}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 48px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);backdrop-filter:blur(16px);background:rgba(7,5,15,.8)}
.nav-logo{font-family:var(--mono);font-size:11px;color:var(--accent);letter-spacing:.1em;flex-shrink:0}
.nav-links{display:flex;gap:24px;list-style:none}
.nav-links a{font-family:var(--mono);font-size:11px;color:var(--muted);text-decoration:none;letter-spacing:.08em;transition:color .2s;position:relative;cursor:none}
.nav-links a::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:var(--accent);transition:width .25s}
.nav-links a:hover{color:var(--text)}
.nav-links a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:16px}
.nav-dot{display:flex;align-items:center;gap:7px;font-family:var(--mono);font-size:11px;color:var(--muted)}
.dot-pulse{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.2}}
.lang-sw{display:flex;align-items:center;border:1px solid var(--border);overflow:hidden}
.lang-btn{padding:5px 10px;background:transparent;border:none;color:var(--muted);cursor:none;font-family:var(--mono);font-size:11px;letter-spacing:.06em;transition:background .2s,color .2s}
.lang-btn.active{background:var(--accent);color:#07050f;font-weight:700}
.lang-btn:hover:not(.active){color:var(--text)}

/* i18n — EN active by default */
[data-lang]{display:none}
[data-lang].active{display:inline}
div[data-lang].active{display:block}
p[data-lang].active{display:block}
h2[data-lang].active{display:block}
span[data-lang].active{display:inline}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:140px 48px 100px;z-index:1}
.hero-coords{font-family:var(--mono);font-size:11px;color:rgba(103,232,194,.32);margin-bottom:32px;letter-spacing:.12em;animation:fadeUp .7s .1s both}
.hero-tag{display:inline-flex;align-items:center;gap:9px;font-family:var(--mono);font-size:11px;color:var(--accent);border:1px solid rgba(103,232,194,.18);padding:7px 14px;margin-bottom:36px;letter-spacing:.08em;width:fit-content;animation:fadeUp .7s .2s both}
.hero-h{font-size:clamp(52px,8.5vw,100px);font-weight:800;line-height:.93;letter-spacing:-.03em;margin-bottom:48px;animation:fadeUp .7s .35s both}
.hero-h .line{display:block}
.hero-h .outline{color:transparent;-webkit-text-stroke:1px rgba(240,238,255,.18)}
.hero-h .teal{color:var(--accent)}
.hero-bottom{display:flex;align-items:flex-end;justify-content:space-between;gap:40px;animation:fadeUp .7s .5s both}
.hero-desc{max-width:400px;font-family:var(--mono);font-size:12px;line-height:1.9;color:var(--muted)}
.hero-actions{display:flex;gap:12px;flex-shrink:0}
.btn-p{display:inline-flex;align-items:center;gap:9px;background:var(--accent);color:#07050f;font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.1em;padding:13px 22px;border:none;cursor:none;text-decoration:none;transition:transform .2s,box-shadow .2s}
.btn-p:hover{transform:translate(-2px,-2px);box-shadow:4px 4px 0 rgba(103,232,194,.18)}
.btn-o{display:inline-flex;align-items:center;gap:8px;background:transparent;color:var(--muted);font-family:var(--mono);font-size:11px;letter-spacing:.08em;padding:13px 22px;border:1px solid var(--border);cursor:none;text-decoration:none;transition:color .2s,border-color .2s}
.btn-o:hover{color:var(--text);border-color:var(--border2)}
.scroll-hint{position:absolute;bottom:44px;left:48px;display:flex;align-items:center;gap:14px;font-family:var(--mono);font-size:10px;color:rgba(240,238,255,.16);letter-spacing:.12em;animation:fadeUp .7s .9s both}
.scroll-line{width:40px;height:1px;background:linear-gradient(90deg,var(--accent),transparent);animation:sp 2.2s 1.5s infinite}
@keyframes sp{0%,100%{opacity:.3}50%{opacity:1}}

/* MARQUEE */
.mq-wrap{position:relative;z-index:1;border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden;padding:13px 0;background:rgba(78,22,179,.05)}
.mq-track{display:flex;gap:44px;width:max-content;animation:mq 24s linear infinite}
.mq-item{font-family:var(--mono);font-size:11px;color:rgba(103,232,194,.32);letter-spacing:.1em;white-space:nowrap;flex-shrink:0}
.mq-item .d{color:var(--purpleL);margin:0 6px}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* SECTIONS */
section{position:relative;z-index:1;padding:88px 48px;border-top:1px solid var(--border)}
.sec-label{font-family:var(--mono);font-size:11px;color:rgba(103,232,194,.42);letter-spacing:.12em;margin-bottom:52px;display:flex;align-items:center;gap:16px}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border);max-width:160px}

/* STATS */
.stats-band{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.stat-c{background:var(--bg);padding:30px 36px;transition:background .2s;cursor:none}
.stat-c:hover{background:var(--surface)}
.stat-n{font-size:36px;font-weight:800;letter-spacing:-.04em;line-height:1;margin-bottom:7px}
.stat-n em{font-style:normal;color:var(--accent)}
.stat-l{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:.06em}

/* PROJECTS */
.proj-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border)}
.proj-c{background:var(--bg);padding:40px;position:relative;overflow:hidden;cursor:none;transition:background .3s}
.proj-c:hover{background:var(--surface)}
.proj-c::before{content:'';position:absolute;top:0;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--purple),var(--accent));transition:width .42s ease}
.proj-c:hover::before{width:100%}
.proj-num{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.22);margin-bottom:18px;letter-spacing:.12em}
.proj-title{font-size:20px;font-weight:700;margin-bottom:11px;letter-spacing:-.02em;line-height:1.2}
.proj-desc{font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.75;margin-bottom:22px}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px}
.tag{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.55);border:1px solid rgba(103,232,194,.1);padding:4px 9px;letter-spacing:.05em}
.proj-arrow{font-size:17px;color:var(--muted);transition:color .2s,transform .2s;display:inline-block;text-decoration:none}
.proj-c:hover .proj-arrow{color:var(--accent);transform:translate(4px,-4px)}
.proj-c.feat{grid-column:span 2;display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:center}
.proj-vis{height:250px;border:1px solid var(--border);background:var(--surface);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.mol-wrap{position:relative;width:160px;height:160px;display:flex;align-items:center;justify-content:center}
.ring{position:absolute;border:1px solid;border-radius:50%}
.r1{width:56px;height:56px;border-color:rgba(103,232,194,.5);animation:spin 5s linear infinite}
.r2{width:96px;height:96px;border-color:rgba(78,22,179,.65);animation:spin 9s linear infinite reverse}
.r3{width:144px;height:144px;border-color:rgba(103,232,194,.14);animation:spin 14s linear infinite}
.ring::after{content:'';position:absolute;top:-4px;left:50%;transform:translateX(-50%);width:7px;height:7px;background:var(--accent);border-radius:50%}
.r2::after{background:var(--purpleL)}
.r3::after{background:rgba(103,232,194,.35);width:5px;height:5px}
.cdot{width:10px;height:10px;background:var(--accent);border-radius:50%;position:relative;z-index:2;box-shadow:0 0 14px rgba(103,232,194,.55)}
.vis-label{position:absolute;font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.28);bottom:11px;left:13px;letter-spacing:.06em}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}

/* TIMELINE */
.timeline{display:flex;flex-direction:column}
.tl-item{display:grid;grid-template-columns:200px 1fr;gap:32px;padding:32px 0;border-bottom:1px solid var(--border);position:relative}
.tl-item::before{content:'';position:absolute;left:199px;top:0;bottom:0;width:1px;background:var(--border)}
.tl-date{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.35);letter-spacing:.08em;margin-bottom:8px}
.tl-company{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:.05em}
.tl-role{font-size:16px;font-weight:700;margin-bottom:10px;letter-spacing:-.01em}
.tl-body{font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.8}
.tl-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:14px}

/* BENTO */
.bento{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border)}
.bento-c{background:var(--bg);padding:36px;transition:background .2s;cursor:none}
.bento-c:hover{background:var(--surface)}
.bento-c.wide{grid-column:span 2}
.bento-label{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.32);letter-spacing:.1em;margin-bottom:16px}
.bento-h{font-size:22px;font-weight:700;letter-spacing:-.02em;margin-bottom:12px;line-height:1.2}
.bento-body{font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.85}
.bento-body p+p{margin-top:12px}
.bento-num{font-size:44px;font-weight:800;letter-spacing:-.04em;line-height:1;margin-bottom:6px}
.bento-num em{font-style:normal;color:var(--accent)}
.skill-row{display:flex;align-items:center;gap:14px;padding:11px 0;border-bottom:1px solid var(--border)}
.skill-row:last-child{border-bottom:none}
.skill-name{font-family:var(--mono);font-size:10px;color:var(--muted);width:80px;flex-shrink:0;letter-spacing:.04em}
.skill-track{flex:1;height:2px;background:rgba(255,255,255,.05)}
.skill-fill{height:100%;background:linear-gradient(90deg,var(--purpleL),var(--accent));width:0%;transition:width 1.4s cubic-bezier(.16,1,.3,1)}
.skill-pct{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.38);width:28px;text-align:right}

/* GALLERY — masonry */
.gallery-masonry{
  columns:3;
  column-gap:1px;
  background:var(--border);
  border:1px solid var(--border);
}
.gallery-item{
  position:relative;
  overflow:hidden;
  break-inside:avoid;
  background:var(--surface);
  cursor:none;
  display:block;
  margin-bottom:1px;
}
.gallery-item img{
  width:100%;
  height:auto;
  display:block;
  transition:transform .55s cubic-bezier(.16,1,.3,1),filter .4s ease;
  filter:grayscale(15%) brightness(0.82);
}
.gallery-item:hover img{transform:scale(1.05);filter:grayscale(0%) brightness(1)}
.g-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to top,rgba(7,5,15,.8) 0%,transparent 50%);
  opacity:0;transition:opacity .35s;
  display:flex;align-items:flex-end;padding:16px;
}
.gallery-item:hover .g-overlay{opacity:1}
.g-caption{font-family:var(--mono);font-size:10px;color:var(--accent);letter-spacing:.1em}
.g-placeholder{
  width:100%;height:200px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:10px;font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.18);letter-spacing:.08em;
}
.g-placeholder svg{width:28px;height:28px;opacity:.15;stroke:var(--accent);fill:none;stroke-width:1.5}

/* MUSIC */
.music-wrap{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border)}
.tracks-side{background:var(--bg);padding:40px}
.tracks-label{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.32);letter-spacing:.1em;margin-bottom:14px}
.tracks-sub{font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.7;margin-bottom:28px}
.tracks-list{display:flex;flex-direction:column}
.s-track{display:flex;align-items:center;gap:14px;padding:13px 0;border-bottom:1px solid var(--border);text-decoration:none;cursor:none;transition:all .2s}
.s-track:last-child{border-bottom:none}
.s-track:hover .s-name{color:var(--accent)}
.s-num{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.22);width:20px;flex-shrink:0}
.s-info{flex:1}
.s-name{font-size:13px;font-weight:700;letter-spacing:-.01em;color:var(--text);transition:color .2s}
.s-artist{font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:3px}
.s-time{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.32);flex-shrink:0;letter-spacing:.04em}
.s-play{width:26px;height:26px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:border-color .2s,background .2s}
.s-track:hover .s-play{border-color:var(--accent);background:rgba(103,232,194,.08)}
.s-play svg{width:9px;height:9px;fill:var(--accent);margin-left:2px}
.s-track.active-track .s-name{color:var(--accent)}
.s-track.active-track .s-play{border-color:var(--accent);background:rgba(103,232,194,.12)}
.s-track.active-track .s-num{color:var(--accent)}
.spotify-iframe-side{background:var(--surface);display:flex;align-items:stretch;min-height:340px}
.spotify-iframe-side iframe{flex:1}

/* ARTICLES */
.articles-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border)}
.art-c{background:var(--bg);padding:40px;position:relative;overflow:hidden;cursor:none;transition:background .3s}
.art-c:hover{background:var(--surface)}
.art-c::before{content:'';position:absolute;top:0;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--purpleL),var(--accent));transition:width .42s}
.art-c:hover::before{width:100%}
.art-tag{font-family:var(--mono);font-size:10px;color:rgba(103,232,194,.35);letter-spacing:.1em;margin-bottom:18px}
.art-title{font-size:18px;font-weight:700;letter-spacing:-.02em;line-height:1.3;margin-bottom:12px}
.art-body{font-family:var(--mono);font-size:11px;color:var(--muted);line-height:1.8;margin-bottom:24px}
.art-link{font-family:var(--mono);font-size:11px;color:var(--accent);text-decoration:none;letter-spacing:.06em;cursor:none;transition:opacity .2s}
.art-link:hover{opacity:.7}

/* FOOTER */
footer{position:relative;z-index:1;border-top:1px solid var(--border);padding:36px 48px;display:flex;align-items:center;justify-content:space-between}
.foot-copy{font-family:var(--mono);font-size:11px;color:rgba(255,255,255,.14)}
.foot-links{display:flex;gap:26px}
.foot-links a{font-family:var(--mono);font-size:11px;color:var(--muted);text-decoration:none;transition:color .2s;letter-spacing:.06em;cursor:none}
.foot-links a:hover{color:var(--accent)}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.reveal{opacity:0;transform:translateY(26px);transition:opacity .65s ease,transform .65s ease}
.reveal.in{opacity:1;transform:none}
@media(max-width:768px){
  body{cursor:auto}
  #cur,#cur-r{display:none}
  nav{padding:14px 20px}
  .nav-links{display:none}
  .nav-dot span{display:none}
  .nav-right{gap:10px}
  .hero{padding:120px 20px 80px}
  .hero-coords{font-size:10px;margin-bottom:20px}
  .hero-bottom{flex-direction:column;align-items:flex-start;gap:24px}
  .hero-actions{flex-direction:column;width:100%}
  .btn-p,.btn-o{width:100%;justify-content:center}
  .scroll-hint{left:20px}
  section{padding:56px 20px}
  .stats-band{grid-template-columns:1fr 1fr}
  .stat-c{padding:20px}
  .stat-n{font-size:28px}
  .proj-grid{grid-template-columns:1fr}
  .proj-c{padding:28px}
  .proj-c.feat{grid-column:span 1;grid-template-columns:1fr;gap:0}
  .proj-vis{height:180px}
  .tl-item{grid-template-columns:1fr;gap:6px;padding:24px 0}
  .tl-item::before{display:none}
  .bento{grid-template-columns:1fr}
  .bento-c{padding:24px}
  .bento-c.wide{grid-column:span 1}
  .gallery-masonry{columns:2;column-gap:1px}
  .music-wrap{grid-template-columns:1fr}
  .tracks-side{padding:24px}
  .spotify-iframe-side{min-height:152px}
  .spotify-iframe-side iframe{min-height:152px}
  .articles-grid{grid-template-columns:1fr}
  .art-c{padding:28px}
  footer{flex-direction:column;gap:16px;padding:28px 20px;text-align:center}
  .foot-links{flex-wrap:wrap;justify-content:center;gap:16px}
}
</style>
</head>
<body>

<div id="cur"></div>
<div id="cur-r"></div>
<div class="grid-bg"></div>
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="noise"></div>

<!-- NAV -->
<nav>
  <div class="nav-logo">AP // v2.0</div>
  <ul class="nav-links">
    <li><a href="#projects"><span data-lang="en" class="active">projects</span><span data-lang="ru">проекты</span></a></li>
    <li><a href="#experience"><span data-lang="en" class="active">experience</span><span data-lang="ru">опыт</span></a></li>
    <li><a href="#about"><span data-lang="en" class="active">about</span><span data-lang="ru">обо мне</span></a></li>
    <li><a href="#gallery"><span data-lang="en" class="active">photos</span><span data-lang="ru">фото</span></a></li>
    <li><a href="#articles"><span data-lang="en" class="active">writing</span><span data-lang="ru">статьи</span></a></li>
    <li><a href="#contact"><span data-lang="en" class="active">contact</span><span data-lang="ru">контакты</span></a></li>
  </ul>
  <div class="nav-right">
    <div class="nav-dot">
      <div class="dot-pulse"></div>
      <span data-lang="en" class="active">available for work</span>
      <span data-lang="ru">открыт к работе</span>
    </div>
    <div class="lang-sw">
      <button class="lang-btn active" data-switch="en">EN</button>
      <button class="lang-btn" data-switch="ru">RU</button>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-coords">41.2995° N, 69.2401° E // TASHKENT, UZ // SYSTEM ONLINE</div>
  <div class="hero-tag">
