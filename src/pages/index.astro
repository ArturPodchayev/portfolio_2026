<script>
// Cursor
const cur=document.getElementById('cur'),ring=document.getElementById('cur-r');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px'});
(function a(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(a)})();
document.querySelectorAll('a,button,.proj-c,.stat-c,.bento-c,.art-c,.tl-item,.gallery-item').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='14px';cur.style.height='14px';ring.style.width='44px';ring.style.height='44px'});
  el.addEventListener('mouseleave',()=>{cur.style.width='8px';cur.style.height='8px';ring.style.width='30px';ring.style.height='30px'});
});

// Language switcher — EN default
let lang='en';
document.querySelectorAll('.lang-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const l=btn.dataset.switch;
    if(l===lang)return;
    lang=l;
    document.querySelectorAll('.lang-btn').forEach(b=>b.classList.toggle('active',b.dataset.switch===l));
    document.querySelectorAll('[data-lang]').forEach(el=>el.classList.toggle('active',el.dataset.lang===l));
    document.querySelectorAll('.en-line').forEach(el=>el.style.display=l==='en'?'block':'none');
    document.querySelectorAll('.ru-line').forEach(el=>el.style.display=l==='ru'?'block':'none');
  });
});

// Marquee
const items=['C# / .NET','Python','AI Agents','Unity VR','Algorithms','Full-Stack','Automation','LeetCode 1000+','Tashkent, UZ','Exority Studio','Systems Thinking','Open to Work'];
const track=document.getElementById('mqt');
track.innerHTML=(items.map(i=>`<span class="mq-item">${i}<span class="d">◆</span></span>`).join('')).repeat(2);

// Track player — click switches iframe src with timestamp
  document.querySelectorAll('.s-track').forEach(track => {
    track.addEventListener('click', () => {
      const id = track.dataset.id;
      const t  = track.dataset.t;
      document.querySelectorAll('.s-track').forEach(t => t.classList.remove('active-track'));
      track.classList.add('active-track');
      document.getElementById('sp-player').src =
        `https://open.spotify.com/embed/track/${id}?t=${t}&utm_source=generator&theme=0`;
    });
  });

const obs=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('in');
      e.target.querySelectorAll('.skill-fill').forEach(b=>setTimeout(()=>b.style.width=b.dataset.w,200));
    }
  });
},{threshold:0.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
</script>
